# ═══════════════════════════════════════════════════════════
# Medical Rehab Agent System — 环境变量配置
# 复制此文件为 .env 后填入实际值
# ═══════════════════════════════════════════════════════════

# ── 方案1: OpenAI ──────────────────────────────────────────
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=sk-your-openai-key
LLM_BASE_URL=

# ── 方案2: DeepSeek（兼容OpenAI SDK）──────────────────────
# LLM_PROVIDER=deepseek
# LLM_MODEL=deepseek-chat
# LLM_API_KEY=sk-your-deepseek-key
# LLM_BASE_URL=https://api.deepseek.com

# ── 方案3: 本地模型（Ollama / vLLM）──────────────────────
# LLM_PROVIDER=local
# LLM_MODEL=qwen2.5:7b
# LLM_API_KEY=not-needed
# LLM_BASE_URL=http://localhost:11434/v1

# ── 方案4: 其他 OpenAI 兼容接口（如硅基流动、通义）──────
# LLM_PROVIDER=openai
# LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
# LLM_API_KEY=sk-your-siliconflow-key
# LLM_BASE_URL=https://api.siliconflow.cn/v1

# ── Embedding 配置 ────────────────────────────────────────
# openai: 使用 OpenAI text-embedding-3-small（语义级，质量高）
# local:  使用内置字符级 embedding（无需API，质量一般）
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small

# ── 其他 ──────────────────────────────────────────────────
LLM_TEMPERATURE=0.3
RAG_TOP_K=3
API_PORT=8000
